SMA_SECRET_KEY=change-me-to-a-random-secret
SMA_DATABASE_URL=sqlite+aiosqlite:///./super_media_app.db
SMA_CORS_ORIGINS=["*"]
SMA_ACCESS_TOKEN_EXPIRE_MINUTES=1440
SMA_MAX_CONCURRENT_DOWNLOADS=3
SMA_RECOGNITION_TIMEOUT_SECONDS=25
# Persistent hosting (e.g. Render free tier, whose local disk gets wiped on
# every redeploy/restart). Leave both blank for local dev — SQLite + local
# files, exactly as above.
#   SMA_DATABASE_URL: point at a managed Postgres instead (e.g. Neon) —
#     paste its connection string as-is; postgresql:// gets normalized to
#     the asyncpg driver automatically, and sslmode/channel_binding query
#     params some dashboards add are stripped automatically too.
#   Storage backend: "local" (default) or "s3" for an S3-compatible bucket
#     (e.g. Cloudflare R2 — free, no egress fees, ideal for streaming).
SMA_STORAGE_BACKEND=local
SMA_S3_ENDPOINT_URL=
SMA_S3_ACCESS_KEY_ID=
SMA_S3_SECRET_ACCESS_KEY=
SMA_S3_BUCKET=
# Optional for public deployments. If set, registration requires this code.
SMA_REGISTRATION_INVITE_CODE=
# Optional for YouTube on cloud hosts. Paste a Netscape cookies.txt export.
SMA_YTDLP_COOKIES_TEXT=
# Optional alternative: base64 of a Netscape cookies.txt file.
SMA_YTDLP_COOKIES_B64=
# Optional alternative when a cookies.txt file exists on disk.
SMA_YTDLP_COOKIES_FILE=
# Optional yt-dlp hardening for cloud hosts.
SMA_YTDLP_IMPERSONATE=chrome
SMA_YTDLP_PROXY_URL=
SMA_YTDLP_YOUTUBE_PLAYER_CLIENTS=
SMA_YTDLP_YOUTUBE_VISITOR_DATA=
SMA_YTDLP_YOUTUBE_PO_TOKEN=
